# Vision-EviDex Environment Configuration
# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit real secrets.

# Licence mode — build-time constant, not a runtime toggle.
#   keygen = standard mode, calls Keygen.sh on first activation
#   none   = no-licence mode, skips activation entirely
# Phase 0 + Phase 1 default: none
EVIDEX_LICENCE_MODE=none

# Code signing — Windows only
#   true   = sign the MSI with CERT_FILE/CERT_PASS
#   false  = skip signing (dev/testing builds only)
EVIDEX_SIGN_BUILD=false

# App secret for PBKDF2 key derivation on .evidex containers.
# Generate on CTS laptop in PowerShell:
#   -join ((1..32) | % { '{0:x2}' -f (Get-Random -Max 256) })
# Store in Windows System Environment Variables AND password manager.
# NEVER commit the real value to git.
EVIDEX_APP_SECRET=replace-with-64-char-hex-string-from-powershell-generator

# Code signing certificate (only needed when EVIDEX_SIGN_BUILD=true)
CERT_FILE=
CERT_PASS=

# Keygen.sh account (only used when EVIDEX_LICENCE_MODE=keygen, Phase 1 Week 4+)
# Names match the env reads in src/main/app.ts (LicenceService bootstrap).
EVIDEX_KEYGEN_ACCOUNT_ID=
EVIDEX_KEYGEN_PRODUCT_ID=
EVIDEX_KEYGEN_PUBLIC_KEY=
