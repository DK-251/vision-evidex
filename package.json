{
  "name": "vision-evidex",
  "version": "0.1.0",
  "description": "Vision-EviDex — offline-first Windows desktop evidence capture and report generation for enterprise QA teams",
  "main": "out/main/app.js",
  "author": "Deepak Sahu <deepak.sahu4@cognizant.com>",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "predev": "npm run rebuild:electron",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "prebuild": "npm run rebuild:electron",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "npm run build && electron-builder --win",
    "dist:standard": "cross-env EVIDEX_LICENCE_MODE=keygen EVIDEX_SIGN_BUILD=true npm run dist",
    "dist:enterprise": "cross-env EVIDEX_LICENCE_MODE=none EVIDEX_SIGN_BUILD=false npm run dist",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "pretest": "npm run rebuild:node",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify-setup": "node scripts/verify-setup.js",
    "report": "node scripts/run-report.js",
    "bench:pbkdf2": "node scripts/benchmark-key-derivation.js",
    "rebuild": "electron-rebuild",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@fluentui/react-icons": "^2.0.226",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.3.0",
    "date-fns": "^3.6.0",
    "docx": "^8.5.0",
    "fabric": "5.3.0",
    "framer-motion": "^11.3.0",
    "jszip": "^3.10.1",
    "node-machine-id": "^1.1.12",
    "sharp": "^0.33.5",
    "ulid": "^2.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/archiver": "^6.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/fabric": "^5.3.9",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.5",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "electron": "^30.4.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.45",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vitest": "^2.0.5"
  }
}
