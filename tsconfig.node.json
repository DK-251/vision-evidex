{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "electron.vite.config.ts",
    "electron-builder.config.js",
    "vitest.config.ts",
    "tailwind.config.js",
    "postcss.config.js",
    "scripts/**/*.js"
  ]
}
